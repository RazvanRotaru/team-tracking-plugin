{
  "name": "team-tracking-mcp-server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "team-tracking": "dist/init/cli.js",
    "team-tracking-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "dev": "tsc --watch -p tsconfig.build.json",
